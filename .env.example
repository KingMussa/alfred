# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create a project at console.cloud.google.com
# Enable: Gmail API + Google Calendar API
# Create OAuth 2.0 credentials (Desktop app type)
# Then run: deno run --allow-net scripts/get-google-tokens.ts
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ── iCloud (Apple Calendar) ───────────────────────────────────────────────────
# Generate an App-Specific Password at appleid.apple.com → Security
# Use your full iCloud email and that app-specific password
ICLOUD_EMAIL=dougiedigital@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Email-to-SMS gateway (replaces Twilio) ───────────────────────────────────
# Free path: Gmail sends to <number>@<carrier-gateway>.
# Carriers: T-Mobile=tmomail.net, AT&T=txt.att.net, Verizon=vtext.com.
FROM_EMAIL=youraddress@gmail.com         # Gmail account already authorized via OAuth
USER_CELL_GATEWAY=5551234567@tmomail.net # 10-digit cell + carrier gateway domain

# ── Telegram (second channel — runs in parallel with SMS gateway) ────────────
# 1. On Dave's phone, open Telegram → search @BotFather → /newbot → name it.
# 2. BotFather replies with a token like 123456:ABC-xxx — paste as TELEGRAM_BOT_TOKEN.
# 3. Open a chat with your new bot, send any message (e.g. "hi").
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates → copy the "chat":{"id":...} value.
# If both vars are blank, Telegram is skipped and only the SMS gateway fires.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Gemini (AI) ────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey — no payment method needed
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
# These are injected automatically at runtime — no need to set manually.
# (Shown here for reference / local testing only)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
